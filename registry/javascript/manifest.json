{
  "extensions": [
    "js",
    "mjs",
    "cjs"
  ],
  "name": "javascript",
  "profile": {
    "containers": [
      [
        "class_declaration",
        "name"
      ]
    ],
    "function_kinds": [
      "function_declaration",
      "method_definition"
    ],
    "identifier_kinds": [
      "identifier",
      "property_identifier"
    ],
    "import_resolution": "relative_path"
  },
  "source": {
    "repo": "tree-sitter/tree-sitter-javascript",
    "rev": "v0.23.1"
  },
  "version": "0.23.1"
}
